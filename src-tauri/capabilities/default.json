{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-execute",
    "updater:default",
    "fs:allow-appdata-write",
    "fs:allow-appdata-write-recursive",
    "fs:allow-mkdir"
  ]
}